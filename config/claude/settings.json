{
  "statusLine": {
    "type": "command",
    "command": "sh $__CLAUDE_NIX/statusline.sh"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "sh $__CLAUDE_NIX/hooks/format.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
